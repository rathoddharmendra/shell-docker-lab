#!/bin/bash

# Configuration
KEY="~/.ssh/oci-ssh-key.key"
HOSTS_FILE="/Users/mac_dee/Documents/Dee/code/shell-docker-lab/scripts/data/hostnames"

# Basic help
if [[ "$1" == "--help" ]]; then
    echo "Usage: sync-oci"
    echo "Syncs the current directory to OCI servers."
    exit 0
fi

# Check if hosts file exists
if [[ ! -f "$HOSTS_FILE" ]]; then
    echo "Error: Hostnames file not found at $HOSTS_FILE"
    exit 1
fi

# Execute
echo "🚀 Starting sync to Oracle Cloud..."
servers=$(cat "$HOSTS_FILE")

for server in $servers; do
    echo "Syncing to $server..."
    # Using rsync for better utility performance
    rsync -avz -e "ssh -i $KEY" ./ opc@$server:~/project/
done

echo "✅ Sync complete!"